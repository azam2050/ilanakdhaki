# Required for production
DATABASE_PUBLIC_URL=postgresql://user:password@host:port/dbname
SESSION_SECRET=replace-with-a-long-random-string

# Salla integration
SALLA_CLIENT_ID=
SALLA_CLIENT_SECRET=
SALLA_WEBHOOK_SECRET=

# Replit AI Integrations (Anthropic) — auto-set on Replit
AI_INTEGRATIONS_ANTHROPIC_BASE_URL=
AI_INTEGRATIONS_ANTHROPIC_API_KEY=

# Optional security alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional flags
NODE_ENV=production
PORT=8080
ALLOW_DEMO_SESSION=false
ALLOW_DEBUG_TRIGGERS=false
DISABLE_OPTIMIZER=false
DISABLE_DAILY_COPY=false
ALLOWED_ORIGINS=https://your-frontend-domain.com
